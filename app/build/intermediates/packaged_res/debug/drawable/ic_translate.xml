<?xml version="1.0" encoding="utf-8"?>
<!--
    Simple "translate" icon — two overlapping speech bubbles with an arrow.
    Renders at any density without blurring.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Globe outline -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#0F172A"
        android:strokeWidth="2"
        android:pathData="M12,2 A10,10 0 1 1 12,22 A10,10 0 1 1 12,2 Z" />

    <!-- Horizontal equator line -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#0F172A"
        android:strokeWidth="1.8"
        android:pathData="M2,12 H22" />

    <!-- Left vertical meridian -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#0F172A"
        android:strokeWidth="1.8"
        android:pathData="M12,2 C8,6 8,18 12,22" />

    <!-- Right vertical meridian -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#0F172A"
        android:strokeWidth="1.8"
        android:pathData="M12,2 C16,6 16,18 12,22" />

    <!-- Small translation arrow overlay -->
    <path
        android:fillColor="#0F172A"
        android:pathData="M15,10 L19,10 L17,8 Z" />
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#0F172A"
        android:strokeWidth="1.6"
        android:pathData="M9,14 L15,14" />

</vector>
