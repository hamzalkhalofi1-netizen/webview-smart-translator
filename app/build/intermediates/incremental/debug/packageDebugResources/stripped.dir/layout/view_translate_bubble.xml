<?xml version="1.0" encoding="utf-8"?>
<!--
    Floating bubble button attached to WindowManager by TranslationService.
    Draggable by the user; tapping toggles the full OverlayView panel.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <ImageButton
        android:id="@+id/btnBubble"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_margin="8dp"
        android:background="@drawable/bg_bubble"
        android:contentDescription="@string/bubble_description"
        android:elevation="8dp"
        android:src="@drawable/ic_translate"
        android:scaleType="centerInside"
        android:padding="12dp"
        android:tint="@color/on_primary" />

</FrameLayout>
