<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Slim monochrome toolbar — blends into the manga black background -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#111111"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#111111"
            app:title="@string/reader_title"
            app:titleTextColor="#FFFFFF"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationIconTint="#FFFFFF" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#222222" />

    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- WebView — renders manga pages or novel text -->
        <WebView
            android:id="@+id/readerWebView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#000000" />

        <!-- Loading overlay -->
        <LinearLayout
            android:id="@+id/layoutLoading"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#000000"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:indeterminateTint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/loading_chapter"
                android:textColor="#888888"
                android:textSize="13sp"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/layoutEmpty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#000000"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_reader"
                android:tint="#333333"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_content"
                android:textColor="#555555"
                android:textSize="15sp"
                android:layout_marginTop="14dp" />

        </LinearLayout>

    </FrameLayout>

    <!-- Prev chapter FAB — bottom-left, monochrome -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabPrevChapter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="20dp"
        android:src="@android:drawable/ic_media_previous"
        android:contentDescription="Previous chapter"
        app:backgroundTint="#1A1A1A"
        app:tint="#FFFFFF"
        app:borderWidth="1dp"
        app:elevation="6dp" />

    <!-- Next chapter FAB — bottom-right, white -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabNextChapter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:src="@android:drawable/ic_media_next"
        android:contentDescription="Next chapter"
        app:backgroundTint="#FFFFFF"
        app:tint="#000000"
        app:elevation="6dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
