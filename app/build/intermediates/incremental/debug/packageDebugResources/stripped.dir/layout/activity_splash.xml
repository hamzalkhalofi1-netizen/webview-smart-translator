<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Main splash content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="48dp">

        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_yomuai_logo"
            android:contentDescription="@string/app_name"
            android:alpha="0" />

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/app_name"
            android:textSize="38sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:letterSpacing="0.05"
            android:alpha="0" />

        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/about_tagline"
            android:textSize="14sp"
            android:textColor="@color/on_surface_muted"
            android:alpha="0" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressIndicator"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="56dp"
            android:indeterminate="true"
            android:alpha="0"
            app:indicatorColor="@color/primary"
            app:trackColor="@color/surface_variant"
            app:trackCornerRadius="4dp" />

    </LinearLayout>

    <!-- No-internet full-screen overlay -->
    <LinearLayout
        android:id="@+id/layoutNoInternet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp"
        android:background="@color/background"
        android:visibility="gone">

        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/ic_wifi_off"
            android:contentDescription="@null"
            android:alpha="0.7" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/splash_no_internet_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/splash_no_internet_msg"
            android:textSize="15sp"
            android:textColor="@color/on_surface_muted"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRetry"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_marginTop="36dp"
            android:text="@string/btn_retry"
            android:textSize="16sp"
            android:paddingStart="40dp"
            android:paddingEnd="40dp"
            app:cornerRadius="28dp"
            app:backgroundTint="@color/primary" />

    </LinearLayout>

</FrameLayout>
