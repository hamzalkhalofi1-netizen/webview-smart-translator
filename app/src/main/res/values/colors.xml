<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ── Monochrome Manga Palette ──────────────────────────────────────── -->

    <!-- Primary = pure white (manga ink on paper feel) -->
    <color name="primary">#FFFFFF</color>
    <color name="primary_dark">#CCCCCC</color>
    <color name="on_primary">#000000</color>

    <!-- Secondary = mid gray -->
    <color name="secondary">#888888</color>
    <color name="secondary_dark">#444444</color>
    <color name="on_secondary">#FFFFFF</color>

    <!-- Backgrounds — deep black like manga night scenes -->
    <color name="background">#000000</color>
    <color name="surface">#111111</color>
    <color name="surface_variant">#1C1C1C</color>
    <color name="on_surface">#FFFFFF</color>
    <color name="on_surface_muted">#888888</color>

    <!-- Error -->
    <color name="error">#FF4444</color>
    <color name="on_error">#000000</color>

    <!-- Overlay UI -->
    <color name="overlay_bg">#E0000000</color>
    <color name="overlay_header">#F0111111</color>
    <color name="overlay_border">#333333</color>
    <color name="text_mask">#F0000000</color>

    <!-- Accent strip used for progress / selection highlight -->
    <color name="accent_strip">#FFFFFF</color>

</resources>
